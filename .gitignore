# ==============================================================
# Jekyll 빌드 산출물
# GitHub Actions가 빌드를 담당하므로 커밋 불필요
# ==============================================================
_site/
.sass-cache/
.jekyll-cache/
.jekyll-metadata

# ==============================================================
# Ruby / Bundler
# ==============================================================
.bundle/
vendor/
*.gem

# ==============================================================
# Node.js
# ==============================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==============================================================
# IDE / 에디터
# ==============================================================

# JetBrains (IntelliJ, RubyMine, WebStorm 등)
.idea/

# Visual Studio Code
.vscode/
*.code-workspace

# Vim / Emacs
*.swp
*.swo
*~
\#*\#

# ==============================================================
# Claude Code CLI
# ==============================================================
.claude/

# ==============================================================
# OS 생성 파일
# ==============================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
.fuse_hidden*
.Trash-*

# ==============================================================
# 로그 / 임시 파일
# ==============================================================
*.log
*.tmp
*.temp
.cache/

# ==============================================================
# 환경 설정 / 시크릿
# ==============================================================
.env
.env.local
.env.*.local

# ==============================================================
# 테스트 산출물
# ==============================================================
coverage/
htmlproofer*.log
